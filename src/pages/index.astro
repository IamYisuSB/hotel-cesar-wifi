---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Hotel Cesar · WiFi Gratis">
  <!-- Language Switcher -->
  <div class="lang-switcher" id="langSwitcher">
    <button class="lang-btn active" data-lang="es" onclick="setLang('es')" title="Español">ES</button>
    <button class="lang-btn" data-lang="en" onclick="setLang('en')" title="English">EN</button>
    <button class="lang-btn" data-lang="ca" onclick="setLang('ca')" title="Català">CA</button>
    <button class="lang-btn" data-lang="fr" onclick="setLang('fr')" title="Français">FR</button>
  </div>

  <!-- Hero Section -->
  <div class="hero">
    <div class="hero-overlay"></div>
    <img
      src="/img/banner.jpg"
      alt="Hotel Cesar - Fachada"
      class="hero-img"
      loading="eager"
    />
    <div class="hero-content">
      <div class="logo">
        <div class="logo-icon">
          <img src="/img/logo.png" alt="Logo Hotel Cesar" class="logo-img" />
        </div>
      </div>
    </div>
  </div>

  <!-- Main Content -->
  <main class="container">
    <div class="wifi-card">
      <div class="wifi-header">
        <div class="wifi-icon">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12.55a11 11 0 0 1 14.08 0"/>
            <path d="M1.42 9a16 16 0 0 1 21.16 0"/>
            <path d="M8.53 16.11a6 6 0 0 1 6.95 0"/>
            <line x1="12" y1="20" x2="12.01" y2="20"/>
          </svg>
        </div>
        <h2 data-i18n="wifi_title">WiFi Gratis</h2>
        <div class="steps">
          <div class="step">
            <div class="step-number">1</div>
            <span data-i18n="step1">Elige una opción</span>
          </div>
          <div class="step-arrow">→</div>
          <div class="step">
            <div class="step-number">2</div>
            <span data-i18n="step2">Completa la acción</span>
          </div>
          <div class="step-arrow">→</div>
          <div class="step">
            <div class="step-number">3</div>
            <span data-i18n="step3">¡Conéctate!</span>
          </div>
        </div>
      </div>

      <!-- Option 1: Email Newsletter -->
      <div class="option-card" id="option-email">
        <div class="option-icon email-icon">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="4" width="20" height="16" rx="2"/>
            <path d="M22 4L12 13L2 4"/>
          </svg>
        </div>
        <div class="option-content">
          <h3 data-i18n="email_title">Suscríbete a nuestro boletín</h3>
          <p data-i18n="email_desc">Recibe ofertas exclusivas y novedades del hotel</p>
        </div>
        <form class="email-form" id="emailForm">
          <div class="input-group">
            <input
              type="email"
              id="emailInput"
              placeholder="tucorreo@ejemplo.com"
              data-i18n-placeholder="email_placeholder"
              required
              autocomplete="email"
            />
            <button type="submit" class="btn btn-primary btn-submit">
              <span class="btn-text" data-i18n="email_btn">Suscribirme</span>
              <span class="btn-loader hidden">
                <svg width="20" height="20" viewBox="0 0 24 24" class="spinner">
                  <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3" fill="none" stroke-dasharray="31.4 31.4" stroke-linecap="round"/>
                </svg>
              </span>
            </button>
          </div>
          <p class="form-note" data-i18n="email_note">No spam. Puedes cancelar cuando quieras.</p>
        </form>
      </div>

      <!-- Option 2: Follow on Instagram -->
      <div class="option-card" id="option-follow">
        <div class="option-icon instagram-icon">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="2" width="20" height="20" rx="5"/>
            <circle cx="12" cy="12" r="5"/>
            <circle cx="17.5" cy="6.5" r="1.5" fill="currentColor" stroke="none"/>
          </svg>
        </div>
        <div class="option-content">
          <h3 data-i18n="follow_title">Síguenos en Instagram</h3>
          <p data-i18n="follow_desc">Descubre momentos únicos de Hotel Cesar</p>
        </div>
        <div class="action-row">
          <button class="btn btn-instagram" id="btnFollow" onclick="openInstagram('follow')">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
              <rect x="2" y="2" width="20" height="20" rx="5" fill="none" stroke="currentColor" stroke-width="2"/>
              <circle cx="12" cy="12" r="5" fill="none" stroke="currentColor" stroke-width="2"/>
            </svg>
            <span data-i18n="follow_btn">Ir a Instagram</span>
          </button>
          <button class="btn btn-confirm hidden" id="btnFollowConfirm" onclick="confirmAction('follow')">
            <span data-i18n="follow_confirm">✓ Ya seguí la cuenta</span>
          </button>
        </div>
      </div>

      <!-- Option 3: Like a Post -->
      <div class="option-card" id="option-like">
        <div class="option-icon like-icon">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
          </svg>
        </div>
        <div class="option-content">
          <h3 data-i18n="like_title">Dale Like a nuestra publicación</h3>
          <p data-i18n="like_desc">Apoya nuestro contenido con un ❤️</p>
        </div>
        <div class="action-row">
          <button class="btn btn-instagram" id="btnLike" onclick="openInstagram('like')">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
              <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
            </svg>
            <span data-i18n="like_btn">Ver publicación</span>
          </button>
          <button class="btn btn-confirm hidden" id="btnLikeConfirm" onclick="confirmAction('like')">
            <span data-i18n="like_confirm">✓ Ya di like</span>
          </button>
        </div>
      </div>

      <!-- Option 4: Google Review -->
      <div class="option-card" id="option-review">
        <div class="option-icon review-icon">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
          </svg>
        </div>
        <div class="option-content">
          <h3 data-i18n="review_title">Déjanos una reseña en Google</h3>
          <p data-i18n="review_desc">Tu opinión nos ayuda a mejorar</p>
        </div>
        <div class="action-row">
          <button class="btn btn-google" id="btnReview" onclick="openGoogle()">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
              <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
            </svg>
            <span data-i18n="review_btn">Ir a Google</span>
          </button>
          <button class="btn btn-confirm hidden" id="btnReviewConfirm" onclick="confirmAction('review')">
            <span data-i18n="review_confirm">✓ Ya dejé mi reseña</span>
          </button>
        </div>
      </div>

      <div class="divider"></div>

      <p class="footer-text">
        <span data-i18n="footer_legal_pre">Al continuar, aceptas nuestros</span> <a href="#" class="link" data-i18n="footer_terms">Términos de Uso</a> <span data-i18n="footer_legal_and">y</span>
        <a href="#" class="link" data-i18n="footer_privacy">Política de Privacidad</a>.
      </p>
    </div>

    <!-- Hotel Info Footer -->
    <footer class="hotel-footer">
      <div class="footer-inner">
        <img
          src="/img/banner.jpg"
          alt="Hotel Cesar"
          class="footer-img"
          loading="lazy"
        />
        <div class="footer-info">
          <h3>Hotel Cesar</h3>
          <p data-i18n="hotel_desc">Una experiencia de hospitalidad incomparable. Lujo, confort y atención personalizada para hacer de tu estancia un momento inolvidable.</p>
          <div class="footer-contact">
            <span>📍 Carrer d'Isaac Peral, 4, 8, 08800 Vilanova i la Geltrú, Barcelona</span>
            <span>📞 +34 93 815 11 25</span>
          </div>
        </div>
      </div>
      <p class="copyright" data-i18n="copyright">© 2026 Hotel Cesar. Todos los derechos reservados.</p>
      <p class="developed-by"><span data-i18n="developed_by">Desarrollado por</span> <a href="https://fooserd.com" target="_blank" rel="noopener noreferrer" class="fooserd-link">Fooserd</a></p>
    </footer>
  </main>

  <!-- Success Modal -->
  <div class="modal-overlay hidden" id="successModal">
    <div class="modal">
      <div class="modal-check">
        <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="var(--success)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"/>
          <path d="M8 12l3 3 5-5"/>
        </svg>
      </div>
      <h2 data-i18n="modal_thanks">¡Gracias!</h2>
      <p data-i18n="modal_desc">Ya puedes conectarte a la red WiFi de Hotel Cesar.</p>
      <div class="wifi-details">
        <div class="wifi-detail-row">
          <span class="label" data-i18n="modal_network">Red:</span>
          <span class="value">hotelcesar</span>
        </div>
        <div class="wifi-detail-row">
          <span class="label" data-i18n="modal_password">Contraseña:</span>
          <span class="value password-value" id="wifiPassword">clienthotelcesar</span>
          <button class="btn-copy" onclick="copyPassword()" title="Copiar contraseña">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="9" y="9" width="13" height="13" rx="2"/>
              <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
            </svg>
          </button>
        </div>
      </div>
      <button class="btn btn-primary btn-full" onclick="closeModal()" data-i18n="modal_accept">Aceptar</button>
      <p class="modal-note" data-i18n="modal_enjoy">Disfruta tu estancia en Hotel Cesar ✨</p>
    </div>
  </div>
</Layout>

<style>
  /* ===== Language Switcher ===== */
  .lang-switcher {
    position: absolute;
    top: 16px;
    right: 16px;
    z-index: 10;
    display: flex;
    gap: 4px;
    background: rgba(0, 0, 0, 0.35);
    backdrop-filter: blur(8px);
    border-radius: 10px;
    padding: 4px;
  }

  .lang-btn {
    background: transparent;
    border: none;
    color: rgba(255, 255, 255, 0.7);
    font-size: 0.72rem;
    font-weight: 600;
    padding: 6px 10px;
    border-radius: 7px;
    cursor: pointer;
    transition: all 0.2s ease;
    letter-spacing: 0.03em;
    font-family: 'Poppins', sans-serif;
  }

  .lang-btn:hover {
    color: var(--white);
    background: rgba(255, 255, 255, 0.15);
  }

  .lang-btn.active {
    background: var(--gold);
    color: var(--white);
    box-shadow: 0 2px 6px rgba(201, 169, 110, 0.4);
  }

  /* ===== Hero ===== */
  .hero {
    position: relative;
    width: 100%;
    height: 340px;
    overflow: hidden;
  }

  .hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 60%;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(26, 26, 46, 0.3) 0%,
      rgba(26, 26, 46, 0.7) 100%
    );
    z-index: 1;
  }

  .hero-content {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 2;
  }

  .logo {
    text-align: center;
    color: var(--white);
  }

  .logo-icon {
    color: var(--gold);
    margin-bottom: 8px;
    filter: drop-shadow(0 2px 8px rgba(201, 169, 110, 0.4));
  }

  .logo-img {
    width: 160px;
    height: auto;
    filter: brightness(0) invert(1) drop-shadow(0 2px 8px rgba(0, 0, 0, 0.3));
  }

  .hotel-name {
    font-size: 2.4rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-shadow: 0 2px 12px rgba(0, 0, 0, 0.3);
  }

  .hotel-tagline {
    font-size: 0.95rem;
    font-weight: 300;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--gold-light);
    margin-top: 4px;
  }

  /* ===== Container ===== */
  .container {
    width: 100%;
    max-width: 480px;
    padding: 0 16px 32px;
    margin-top: -40px;
    position: relative;
    z-index: 3;
  }

  /* ===== WiFi Card ===== */
  .wifi-card {
    background: var(--white);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-lg);
    padding: 32px 24px;
    margin-bottom: 24px;
  }

  .wifi-header {
    text-align: center;
    margin-bottom: 28px;
  }

  .wifi-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 72px;
    height: 72px;
    background: linear-gradient(135deg, var(--gold), var(--gold-dark));
    border-radius: 50%;
    color: var(--white);
    margin-bottom: 16px;
    box-shadow: 0 4px 16px rgba(201, 169, 110, 0.35);
  }

  .wifi-header h2 {
    font-size: 1.6rem;
    color: var(--dark);
    margin-bottom: 8px;
  }

  .wifi-subtitle {
    font-size: 0.9rem;
    color: var(--text-light);
    line-height: 1.5;
    max-width: 320px;
    margin: 0 auto;
  }

  /* ===== Steps ===== */
  .steps {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    margin-top: 16px;
    flex-wrap: nowrap;
    padding: 0 4px;
  }

  .step {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    min-width: 0;
    flex: 1;
  }

  .step-number {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--gold), var(--gold-dark));
    color: var(--white);
    font-size: 0.85rem;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 2px 8px rgba(201, 169, 110, 0.3);
    flex-shrink: 0;
  }

  .step span {
    font-size: 0.72rem;
    color: var(--text-light);
    font-weight: 500;
    text-align: center;
    word-break: break-word;
  }

  .step-arrow {
    color: var(--gold-light);
    font-size: 1.1rem;
    margin-top: -14px;
    flex-shrink: 0;
  }

  /* ===== Option Cards ===== */
  .option-card {
    background: var(--cream);
    border: 1px solid var(--cream-dark);
    border-radius: var(--radius);
    padding: 20px;
    margin-bottom: 14px;
    transition: all 0.25s ease;
  }

  .option-card:hover {
    border-color: var(--gold-light);
    box-shadow: 0 2px 12px rgba(201, 169, 110, 0.15);
  }

  .option-card .option-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    border-radius: 12px;
    margin-bottom: 12px;
  }

  .email-icon { background: #eef4ff; color: #4a7cff; }
  .instagram-icon { background: #ffeef5; color: #e1306c; }
  .like-icon { background: #fff0f0; color: #ff4757; }
  .review-icon { background: #fff8ee; color: #f39c12; }

  .option-content h3 {
    font-family: 'Poppins', sans-serif;
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 4px;
    color: var(--dark);
  }

  .option-content p {
    font-size: 0.82rem;
    color: var(--text-light);
    margin-bottom: 14px;
  }

  /* ===== Email Form ===== */
  .email-form {
    margin-top: 4px;
  }

  .input-group {
    display: flex;
    gap: 8px;
  }

  .input-group input {
    flex: 1;
    padding: 12px 16px;
    border: 1.5px solid var(--cream-dark);
    border-radius: 10px;
    font-size: 0.9rem;
    background: var(--white);
    color: var(--text);
    transition: border-color 0.2s;
    outline: none;
  }

  .input-group input:focus {
    border-color: var(--gold);
  }

  .input-group input::placeholder {
    color: #b0b0b0;
  }

  .form-note {
    font-size: 0.72rem;
    color: var(--text-light);
    margin-top: 8px;
    text-align: center;
  }

  /* ===== Buttons ===== */
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 12px 20px;
    border-radius: 10px;
    font-size: 0.88rem;
    font-weight: 500;
    transition: all 0.25s ease;
    white-space: nowrap;
  }

  .btn-primary {
    background: linear-gradient(135deg, var(--gold), var(--gold-dark));
    color: var(--white);
    box-shadow: 0 2px 8px rgba(201, 169, 110, 0.3);
  }

  .btn-primary:hover {
    box-shadow: 0 4px 16px rgba(201, 169, 110, 0.45);
    transform: translateY(-1px);
  }

  .btn-instagram {
    background: linear-gradient(135deg, #833ab4, #e1306c, #fd1d1d);
    color: var(--white);
    box-shadow: 0 2px 8px rgba(225, 48, 108, 0.3);
  }

  .btn-instagram:hover {
    box-shadow: 0 4px 16px rgba(225, 48, 108, 0.45);
    transform: translateY(-1px);
  }

  .btn-google {
    background: linear-gradient(135deg, #4285f4, #34a853);
    color: var(--white);
    box-shadow: 0 2px 8px rgba(66, 133, 244, 0.3);
  }

  .btn-google:hover {
    box-shadow: 0 4px 16px rgba(66, 133, 244, 0.45);
    transform: translateY(-1px);
  }

  .btn-confirm {
    background: var(--success);
    color: var(--white);
    box-shadow: 0 2px 8px rgba(46, 204, 113, 0.3);
    animation: fadeIn 0.3s ease;
  }

  .btn-confirm:hover {
    box-shadow: 0 4px 16px rgba(46, 204, 113, 0.45);
    transform: translateY(-1px);
  }

  .btn-full {
    width: 100%;
    padding: 14px;
    font-size: 1rem;
  }

  .btn-submit {
    min-width: 120px;
  }

  .action-row {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }

  /* ===== Utilities ===== */
  .hidden {
    display: none !important;
  }

  .divider {
    height: 1px;
    background: var(--cream-dark);
    margin: 20px 0 16px;
  }

  .footer-text {
    font-size: 0.75rem;
    color: var(--text-light);
    text-align: center;
    line-height: 1.6;
  }

  .link {
    color: var(--gold-dark);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  /* ===== Spinner ===== */
  .spinner {
    animation: spin 1s linear infinite;
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: scale(0.95); }
    to { opacity: 1; transform: scale(1); }
  }

  /* ===== Modal ===== */
  .modal-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.6);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 100;
    padding: 20px;
    backdrop-filter: blur(4px);
    animation: fadeIn 0.3s ease;
  }

  .modal {
    background: var(--white);
    border-radius: var(--radius-lg);
    padding: 36px 28px;
    max-width: 400px;
    width: 100%;
    text-align: center;
    box-shadow: var(--shadow-lg);
    animation: slideUp 0.4s ease;
  }

  @keyframes slideUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .modal-check {
    margin-bottom: 16px;
  }

  .modal h2 {
    font-size: 1.6rem;
    color: var(--dark);
    margin-bottom: 8px;
  }

  .modal > p {
    font-size: 0.9rem;
    color: var(--text-light);
    margin-bottom: 20px;
  }

  .wifi-details {
    background: var(--cream);
    border-radius: var(--radius);
    padding: 16px 20px;
    margin-bottom: 20px;
  }

  .wifi-detail-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 6px 0;
    font-size: 0.88rem;
    gap: 8px;
  }

  .password-value {
    font-family: 'Courier New', monospace;
    letter-spacing: 0.05em;
  }

  .btn-copy {
    background: none;
    border: none;
    color: var(--text-light);
    padding: 4px;
    border-radius: 6px;
    cursor: pointer;
    transition: color 0.2s;
    flex-shrink: 0;
  }

  .btn-copy:hover {
    color: var(--gold-dark);
  }

  .wifi-detail-row .label {
    color: var(--text-light);
  }

  .wifi-detail-row .value {
    font-weight: 600;
    color: var(--dark);
  }

  .modal-note {
    font-size: 0.8rem;
    color: var(--text-light);
    margin-top: 12px;
  }

  /* ===== Hotel Footer ===== */
