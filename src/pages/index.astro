  function setLang(lang: string) {
    const dict = translations[lang];
    if (!dict) return;

    // Update all data-i18n text elements
    document.querySelectorAll('[data-i18n]').forEach((el) => {
      const key = el.getAttribute('data-i18n')!;
      if (dict[key]) el.textContent = dict[key];
    });

    // Update placeholders
    document.querySelectorAll('[data-i18n-placeholder]').forEach((el) => {
      const key = el.getAttribute('data-i18n-placeholder')!;
      if (dict[key]) (el as HTMLInputElement).placeholder = dict[key];
    });

    // Update active button
    document.querySelectorAll('.lang-btn').forEach((btn) => {
      btn.classList.toggle('active', btn.getAttribute('data-lang') === lang);
    });

    // Update html lang attribute
    document.documentElement.lang = lang;

    // Persist preference
    localStorage.setItem('hotel_lang', lang);
  }

  // Auto-detect language on page load
  function detectLang(): string {
    // 1. Check stored preference
    const stored = localStorage.getItem('hotel_lang');
    if (stored && translations[stored]) return stored;

    // 2. Detect from browser
    const browserLang = navigator.language.toLowerCase();
    if (browserLang.startsWith('ca')) return 'ca';
    if (browserLang.startsWith('en')) return 'en';
    if (browserLang.startsWith('fr')) return 'fr';
    // Default to Spanish
    return 'es';
  }

  // Apply language on load
  const detectedLang = detectLang();
  if (detectedLang !== 'es') {
    setLang(detectedLang);
  } else {
    // Still mark the active button for 'es'
    document.querySelectorAll('.lang-btn').forEach((btn) => {
      btn.classList.toggle('active', btn.getAttribute('data-lang') === 'es');
    });
  }

  (window as any).setLang = setLang;
