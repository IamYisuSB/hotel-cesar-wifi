  // ===== Timer-based confirm buttons =====
  function openInstagram(type: string) {
    const url = type === 'follow' ? CONFIG.instagramProfile : CONFIG.instagramPost;
    // Some desktop browsers block popups; fallback to same-tab navigation.
    const openedWindow = window.open(url, '_blank', 'noopener,noreferrer');
    if (!openedWindow) {
      window.location.href = url;
    }

    const confirmBtn = document.getElementById(
      type === 'follow' ? 'btnFollowConfirm' : 'btnLikeConfirm'
    );

    // Show confirm button after delay
    setTimeout(() => {
      confirmBtn?.classList.remove('hidden');
    }, CONFIG.confirmDelay);
  }

  function openGoogle() {
    // Some desktop browsers block popups; fallback to same-tab navigation.
    const openedWindow = window.open(CONFIG.googleReview, '_blank', 'noopener,noreferrer');
    if (!openedWindow) {
      window.location.href = CONFIG.googleReview;
    }

    setTimeout(() => {
      document.getElementById('btnReviewConfirm')?.classList.remove('hidden');
    }, CONFIG.confirmDelay);
  }

  function confirmAction(_action: string) {
    showSuccess();
