---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Hotel Cesar - WiFi Gratis para Huéspedes" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  *,
  *::before,
  *::after {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  :root {
    --gold: #c9a96e;
    --gold-light: #e4d5b7;
    --gold-dark: #a68745;
    --dark: #1a1a2e;
    --dark-light: #16213e;
    --cream: #faf7f2;
    --cream-dark: #f0ebe0;
    --text: #2d2d2d;
    --text-light: #6b6b6b;
    --white: #ffffff;
    --success: #2ecc71;
    --shadow: 0 4px 24px rgba(0, 0, 0, 0.08);
    --shadow-lg: 0 8px 40px rgba(0, 0, 0, 0.12);
    --radius: 12px;
    --radius-lg: 20px;
  }

  html {
    font-family: 'Poppins', system-ui, sans-serif;
    color: var(--text);
    background: var(--cream);
    scroll-behavior: smooth;
  }

  body {
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
    align-items: center;
    overflow-x: hidden;
  }

  h1, h2, h3, h4 {
    font-family: 'Poppins', system-ui, sans-serif;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  button {
    font-family: inherit;
    cursor: pointer;
    border: none;
  }

  input {
    font-family: inherit;
  }
</style>
